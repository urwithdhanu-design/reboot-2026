# Optional: read marketplace catalog from Firestore (gcul_cache/policy_marketplace).
# Falls back to /api/products when unset. Use same Firebase project as GCP (e.g. community-hub-6fb1b).
# VITE_FIRESTORE_CACHE=true
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=community-hub-6fb1b
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
