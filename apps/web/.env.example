# Copy to .env.local — Vite loads it automatically.

VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Dev API routing:
#   (unset)              → Vite proxies /api/* to localhost:8081–8090
#   VITE_API_PROXY=cloud → Vite proxies /api/* to URLs in deploy/cloud-api.targets.json
VITE_API_PROXY=cloud

# Production: leave empty when the SPA is on Firebase Hosting (rewrites /api/* to Cloud Run).
# VITE_API_BASE=
