# Gmail SMTP — use an App Password (not your regular Gmail password)
# Same approach as Kindred Circle CRM (email-api)

EMAIL_USER=your@gmail.com
EMAIL_PASS=your-16-char-app-password

# Shown as the From display name on every outbound email
EMAIL_FROM_NAME=Reboot 2026 Insurance platform

# Set to false to disable sending without removing keys
# EMAIL_ENABLED=true
