# Stripe keys for policy-service (secret stays on the server)
# Copy to .env in this folder and fill in your test keys from https://dashboard.stripe.com/test/apikeys

STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Optional overrides (defaults work for local Vite on :5173)
# STRIPE_SUCCESS_URL=http://localhost:5173/payment/success
# STRIPE_CANCEL_URL=http://localhost:5173/payment/cancel

# Gmail SMTP (same as Kindred CRM — App Password)
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-16-char-app-password
EMAIL_FROM_NAME=Reboot 2026 Insurance platform
