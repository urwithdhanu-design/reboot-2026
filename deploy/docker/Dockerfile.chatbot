# syntax=docker/dockerfile:1
FROM python:3.12-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

COPY apps/services/chatbot-assistance-service/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY apps/services/chatbot-assistance-service/app /app/app
COPY apps/services/chatbot-assistance-service/application.properties /app/application.properties
COPY apps/services/chatbot-assistance-service/knowledge /app/knowledge

ENV PORT=8080 \
    CHATBOT_AUTO_INGEST=false
EXPOSE 8080
CMD ["sh", "-c", "uvicorn app.main:app --host 0.0.0.0 --port ${PORT}"]
